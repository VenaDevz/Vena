# Reown (WalletConnect) — ücretsiz Project ID
# https://dashboard.reown.com adresinden oluşturun
#
# ÖNEMLİ: Bu dosya sadece şablondur — Next.js bunu OKUMAZ!
# Gerçek ID'nizi .env.local dosyasına yazın (git'e gitmez).
NEXT_PUBLIC_REOWN_PROJECT_ID=your_project_id_here

# Production URL (wallet metadata için)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Robinhood Chain (varsayılan) — token + NFT burada deploy edilir
# Testnet: NEXT_PUBLIC_CHAIN_ID=46630
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=4663
NEXT_PUBLIC_NETWORK=Robinhood Chain
NEXT_PUBLIC_RH_RPC=https://rpc.mainnet.chain.robinhood.com
# NEXT_PUBLIC_RH_TESTNET_RPC=https://rpc.testnet.chain.robinhood.com

# NFT + Forge (Robinhood Chain)
# Silver mint: 0.01 ETH. Upgrades pay $VENA (enabled after VENA_TOKEN is set).
NEXT_PUBLIC_PICKAXE_NFT=
NEXT_PUBLIC_FORGE=
NEXT_PUBLIC_STAKING=

# $VENA — Virtuals launch (Robinhood Chain)
# Contract address on RH Chain (from Virtuals / Blockscout after launch):
NEXT_PUBLIC_VENA_TOKEN=
# Trade & agent page (live)
NEXT_PUBLIC_VIRTUALS_AGENT_URL=https://app.virtuals.io/virtuals/95873

# Pinata / IPFS images for site UI (full HTTPS gateway URLs)
# NEXT_PUBLIC_PICKAXE_IMAGE_SILVER=https://gateway.pinata.cloud/ipfs/Qm...
# NEXT_PUBLIC_PICKAXE_IMAGE_GOLD=https://gateway.pinata.cloud/ipfs/Qm...
# NEXT_PUBLIC_PICKAXE_IMAGE_PLATINUM=https://gateway.pinata.cloud/ipfs/Qm...
# NEXT_PUBLIC_PICKAXE_IMAGE_DIAMOND=https://gateway.pinata.cloud/ipfs/Qm...
# NEXT_PUBLIC_PICKAXE_IMAGE_EMERALD=https://gateway.pinata.cloud/ipfs/Qm...

# Miner Command demo inventory (comma-separated token IDs, optional)
# NEXT_PUBLIC_MINER_DEMO_PICKAXES=1,2,3
