# Reown (WalletConnect) — ücretsiz Project ID
# https://dashboard.reown.com adresinden oluşturun
#
# ÖNEMLİ: Bu dosya sadece şablondur — Next.js bunu OKUMAZ!
# Gerçek ID'nizi .env.local dosyasına yazın (git'e gitmez).
NEXT_PUBLIC_REOWN_PROJECT_ID=your_project_id_here

# Production URL (wallet metadata için)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Robinhood Chain (varsayılan) — token + NFT burada deploy edilir
# Testnet: NEXT_PUBLIC_CHAIN_ID=46630
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=4663
NEXT_PUBLIC_NETWORK=Robinhood Chain
NEXT_PUBLIC_RH_RPC=https://rpc.mainnet.chain.robinhood.com
# NEXT_PUBLIC_RH_TESTNET_RPC=https://rpc.testnet.chain.robinhood.com

# NFT + Forge (Robinhood Chain mainnet — defaults baked in if unset)
NEXT_PUBLIC_PICKAXE_NFT=0xe250751a2514e0d1267AcBEBF43787aF579b6F4c
NEXT_PUBLIC_FORGE=0x99A1ac88eeB9eFFF12Be0607F4089c40F6765823
NEXT_PUBLIC_STAKING=0x1dDA64bd76165400Ad929D4d94E0D8285288D37B
# V3 + loadout parked for later (Stratum/accessories) — do not set as STAKING yet
# NEXT_PUBLIC_STAKING_V3=0xa3B98AE4aE2257bA279E9C7AB84c9EcfF5535f7e
# NEXT_PUBLIC_LOADOUT=0x29865b0A6a9fA520b9d5DE47434c76936D032bcb
# Set true only when announcing staking publicly (duyuru anında true yap)
NEXT_PUBLIC_STAKING_LIVE=false
# Accessory shop + level upgrades (on-chain flags must also be enabled)
NEXT_PUBLIC_LOADOUT_LIVE=false

# $VENA — Virtuals launch (Robinhood Chain)
NEXT_PUBLIC_VENA_TOKEN=0xFbD1Bf9d354CD8197Ab54f80778C03cc468ADAaf
VENA_TOKEN=0xFbD1Bf9d354CD8197Ab54f80778C03cc468ADAaf
# Trade & agent page (live)
NEXT_PUBLIC_VIRTUALS_AGENT_URL=https://app.virtuals.io/virtuals/95873

# Pinata / IPFS images for site UI (full HTTPS gateway URLs)
# NEXT_PUBLIC_PICKAXE_IMAGE_SILVER=https://gateway.pinata.cloud/ipfs/Qm...
# NEXT_PUBLIC_PICKAXE_IMAGE_GOLD=https://gateway.pinata.cloud/ipfs/Qm...
# NEXT_PUBLIC_PICKAXE_IMAGE_PLATINUM=https://gateway.pinata.cloud/ipfs/Qm...
# NEXT_PUBLIC_PICKAXE_IMAGE_DIAMOND=https://gateway.pinata.cloud/ipfs/Qm...
# NEXT_PUBLIC_PICKAXE_IMAGE_EMERALD=https://gateway.pinata.cloud/ipfs/Qm...

# Miner Command demo inventory (comma-separated token IDs, optional)
# NEXT_PUBLIC_MINER_DEMO_PICKAXES=1,2,3

# ─────────────────────────────────────────────────────────────
# Treasury keeper (local/server — NEVER commit real keys)
# Script: scripts/treasury-buyback.mjs
# ─────────────────────────────────────────────────────────────
# PRIVATE_KEY=0x...                    # deployer (forge deploy only)
# TREASURY=0x882db6c850f866Af6f050335540bf3da4CB0dfcA
# TREASURY_PRIVATE_KEY=0x...           # treasury signer (buyback + fundRewards)
# FUNDING_OPERATOR=0x882db6c850f866Af6f050335540bf3da4CB0dfcA
# MINING=0x1dDA64bd76165400Ad929D4d94E0D8285288D37B
# RH_RPC=https://rpc.mainnet.chain.robinhood.com
#
# Keeper thresholds:
# GAS_RESERVE_ETH=0.01                 # always keep this ETH for gas
# MIN_SWAP_ETH=0.02                      # min excess ETH before buyback
# MIN_FUND_VENA=1000                     # min treasury VENA before fundRewards
# SLIPPAGE_BPS=2000                      # max 20% (hard cap in script)
# KEEPER_INTERVAL_MINUTES=30             # --watch loop interval
#
# Commands:
#   npm run treasury:keeper              # dry-run (preview cycle)
#   npm run treasury:keeper:run          # execute: buyback (if ETH) + fund pool
#   npm run treasury:keeper:watch        # execute every 30 min (daemon)
#   npm run treasury:fund:run            # fund-only execute
