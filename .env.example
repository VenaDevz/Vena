# Reown (WalletConnect) — ücretsiz Project ID
# https://dashboard.reown.com adresinden oluşturun
#
# ÖNEMLİ: Bu dosya sadece şablondur — Next.js bunu OKUMAZ!
# Gerçek ID'nizi .env.local dosyasına yazın (git'e gitmez).
NEXT_PUBLIC_REOWN_PROJECT_ID=your_project_id_here

# Production URL (wallet metadata için)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Base mainnet contracts (v4 live)
NEXT_PUBLIC_VENA_TOKEN=0xFE96b62c837F85f453a9b42ad1304C10588181fA
NEXT_PUBLIC_PICKAXE_NFT=0x7483224018be072F36C83CDdDB0aD9Cc4bF8EEe5
NEXT_PUBLIC_VENA_MINING=0xF61C1a1959FDAf77F1A3FaE3F62a6163b2e1248C
NEXT_PUBLIC_FORGE=0x067855B1d9f789be04c67B3fE2F322b454194510
NEXT_PUBLIC_SWAP_ROUTER=0xD88398adBD2ddAFa4ac6aE98Ea6F5326bf9EcDBf
NEXT_PUBLIC_HOOK_ADDRESS=0xb1148A5ab21dc295F8e41fB57505aBD910344044
NEXT_PUBLIC_VENA_POOL_ID=0x69dcdab302d501d55863810b6039498b09308c8e81f698b58824eb08b5ac13b4

# "0" = Buy button scrolls to on-site #swap (default). "1" = Buy opens Uniswap (after LP live).
NEXT_PUBLIC_BUY_VIA_UNISWAP=0

# Optional: override Uniswap buy deep link
# NEXT_PUBLIC_UNISWAP_BUY_URL=https://app.uniswap.org/swap?chain=base&inputCurrency=NATIVE&outputCurrency=0xFE96...

# Pinata / IPFS images for site UI (full HTTPS gateway URLs)
# NEXT_PUBLIC_PICKAXE_IMAGE_SILVER=https://gateway.pinata.cloud/ipfs/Qm...
# NEXT_PUBLIC_PICKAXE_IMAGE_GOLD=https://gateway.pinata.cloud/ipfs/Qm...
# NEXT_PUBLIC_PICKAXE_IMAGE_PLATINUM=https://gateway.pinata.cloud/ipfs/Qm...
# NEXT_PUBLIC_PICKAXE_IMAGE_DIAMOND=https://gateway.pinata.cloud/ipfs/Qm...
# NEXT_PUBLIC_PICKAXE_IMAGE_EMERALD=https://gateway.pinata.cloud/ipfs/Qm...
