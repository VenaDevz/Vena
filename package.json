{
  "name": "vena",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "forge:build": "forge build",
    "forge:deploy:nft": "forge script script/robinhood/DeployNFT.s.sol --rpc-url robinhood --broadcast",
    "forge:deploy:forge": "forge script script/robinhood/DeployForge.s.sol --rpc-url robinhood --broadcast",
    "forge:deploy:mining": "forge script script/robinhood/DeployMining.s.sol --rpc-url robinhood --broadcast",
    "forge:deploy:mining-v2": "forge script script/robinhood/DeployMiningV2.s.sol --rpc-url robinhood --broadcast",
    "treasury:keeper": "node scripts/treasury-buyback.mjs",
    "treasury:keeper:run": "node scripts/treasury-buyback.mjs --execute",
    "treasury:keeper:watch": "node scripts/treasury-buyback.mjs --execute --watch",
    "treasury:buyback": "node scripts/treasury-buyback.mjs --buyback-only",
    "treasury:fund": "node scripts/treasury-buyback.mjs --fund-only",
    "treasury:fund:run": "node scripts/treasury-buyback.mjs --fund-only --execute"
  },
  "dependencies": {
    "@reown/appkit": "^1.8.20",
    "@reown/appkit-adapter-wagmi": "^1.8.20",
    "@tanstack/react-query": "^5.101.0",
    "ethers": "^6.16.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "viem": "^2.52.2",
    "wagmi": "^3.6.16",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
